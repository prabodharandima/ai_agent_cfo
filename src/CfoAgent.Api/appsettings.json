{
  "Application": {
    "Name": "CFO AI Agent",
    "DemoMode": true
  },
  "AI": {
    "Provider": "Ollama",
    "Ollama": {
      "Model": "llama3.2:3b",
      "BaseUrl": "http://localhost:11434",
      "TimeoutSeconds": 120,
      "Temperature": 0,
      "ContextLength": 4096,
      "MaxOutputTokens": 512
    }
  },
  "Chroma": {
    "BaseUrl": "http://localhost:8000",
    "CollectionName": "cfo-financial-knowledge",
    "Tenant": "default_tenant",
    "Database": "default_database",
    "TimeoutSeconds": 10
  },
  "Rag": {
    "KnowledgeFilesRoot": "../../data/knowledge",
    "MaxChunkCharacters": 1200,
    "MaxKnowledgeContextCharacters": 4000,
    "MaximumRetrievalDistance": 1.25
  },
  "Mcp": {
    "Finance": {
      "Enabled": true,
      "BaseUrl": "http://localhost:5081",
      "TimeoutSeconds": 10,
      "AllowedToolNames": [
        "get_sales_summary",
        "compare_sales_periods",
        "get_top_products",
        "get_historical_sales",
        "get_budget_target"
      ]
    },
    "KnowledgeFiles": {
      "Enabled": false,
      "BaseUrl": "http://localhost:5082",
      "RootPath": "data/knowledge",
      "UseLocalFallback": false,
      "TimeoutSeconds": 10,
      "AllowedToolNames": [
        "list_knowledge_files",
        "read_knowledge_file"
      ]
    }
  },
  "Frontend": {
    "AllowedOrigin": "http://localhost:5173"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "AllowedHosts": "*"
}
