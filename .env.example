# Copy this file to .env and change values for your local Docker deployment.
# .env is ignored by Git. Do not commit real passwords or other secrets.
POSTGRES_DB=cfo_agent
POSTGRES_USER=cfo_agent
POSTGRES_PASSWORD=change-this-local-password
FINANCE_DATABASE_CONNECTION_STRING=Host=postgres;Port=5432;Database=cfo_agent;Username=cfo_agent;Password=change-this-local-password
FINANCE_DEMO_DATE=2026-07-15

ASPNETCORE_ENVIRONMENT=Production
AI_PROVIDER=Mock
AI_MODEL=DeterministicMock
OLLAMA_BASE_URL=http://host.docker.internal:11434
AI_TIMEOUT_SECONDS=120
AI_TEMPERATURE=0
AI_CONTEXT_LENGTH=4096
AI_MAX_OUTPUT_TOKENS=512

CHROMA_BASE_URL=http://chromadb:8000
CHROMA_COLLECTION_NAME=cfo-financial-knowledge
CHROMA_TENANT=default_tenant
CHROMA_DATABASE=default_database
CHROMA_TIMEOUT_SECONDS=10

RAG_KNOWLEDGE_FILES_ROOT=/knowledge
RAG_MAX_CHUNK_CHARACTERS=1200
RAG_MAX_KNOWLEDGE_CONTEXT_CHARACTERS=4000
RAG_MAXIMUM_RETRIEVAL_DISTANCE=1.25

FINANCE_MCP_ENABLED=true
FINANCE_MCP_BASE_URL=http://finance-mcp:8080
FINANCE_MCP_TIMEOUT_SECONDS=10
KNOWLEDGE_MCP_ENABLED=true
KNOWLEDGE_MCP_BASE_URL=http://knowledge-mcp:8080
KNOWLEDGE_MCP_ROOT_PATH=/knowledge
KNOWLEDGE_MCP_USE_LOCAL_FALLBACK=false
KNOWLEDGE_MCP_TIMEOUT_SECONDS=10

FRONTEND_ALLOWED_ORIGIN=http://localhost:5173
VITE_API_BASE_URL=
CFO_API_PORT=5260
CFO_UI_PORT=5173

RAG_INIT_AI_PROVIDER=Mock
RAG_INIT_AI_MODEL=DeterministicMock
RAG_INIT_ASPNETCORE_ENVIRONMENT=Development
RAG_INIT_FINANCE_MCP_ENABLED=false
RAG_INIT_KNOWLEDGE_MCP_ENABLED=false
RAG_INIT_KNOWLEDGE_MCP_USE_LOCAL_FALLBACK=false
